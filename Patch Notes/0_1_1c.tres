patch_notes = "New Features:\\n- Added control menu to display control mappings to the end users\\n- resolution scaling has been added\\n\\nBug Fixes\\n-Codebase refactored from end-to-end for efficiency"
known_issues = "Known Issues:\\n-Rail pathing is not as clean as i'd like it to be.\\n-Control mappings are not accessible to the user anywhere\\n-The following buildings are presently not added to the game:\\n     -Transportation-Rails\\n          -Multirail 3\\n          -Multirail 5\\n          -Rail Modulator 5\\n     -Transportation-Shipment\\n          -Orbital Cargo Launcher\\n          -Teleporter\\n     -Transportation-Storage\\n          -All Buildings"
